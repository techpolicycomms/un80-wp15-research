# Copy to .env and fill after saving the webhook automation in Cursor
#
# WEBHOOK_URL = copy the full Webhook URL from Cursor (starts with https://)
# WEBHOOK_API_KEY = copy ONLY the key/token — NOT "Authorization: Bearer "
#
# Correct:
#   WEBHOOK_API_KEY=crsr_abc123...
# Wrong:
#   WEBHOOK_API_KEY=Authorization: Bearer crsr_abc123...

WEBHOOK_URL=
WEBHOOK_API_KEY=

# Optional — academic evidence scripts (see docs/ACADEMIC-RIGOUR.md)
OPENALEX_MAILTO=
UNPAYWALL_EMAIL=

# Optional — multi-model synthesis engine (npm run orchestrate)
# Keys are read at build time only; the deployed static site never contains them.
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
# CLAUDE_PROVIDER=cli   # force the Claude stage through the local `claude` CLI (subscription auth, no API credits)

# Optional — innovation-jobs collector (npm run collect:jobs)
# Free self-serve appname: https://apidoc.reliefweb.int/parameters#appname
RELIEFWEB_APPNAME=
