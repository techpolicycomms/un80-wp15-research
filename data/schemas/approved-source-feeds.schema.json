{
  "$id": "approved-source-feeds.schema.json",
  "type": "object",
  "required": ["meta", "feeds"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["updated", "disclaimer"],
      "properties": {
        "updated": { "type": "string", "format": "date" },
        "disclaimer": { "type": "string" },
        "usage": { "type": "string" }
      }
    },
    "feeds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "url", "check_frequency", "relevance", "evidence_tier", "topics"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "url": { "type": "string", "format": "uri" },
          "check_frequency": { "enum": ["daily", "weekly", "monthly"] },
          "relevance": { "enum": ["action_61", "action_62", "both"] },
          "evidence_tier": { "enum": ["A", "B", "C", "D", "E"] },
          "topics": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
