{
  "$id": "secondary-source.schema.json",
  "type": "object",
  "required": ["meta", "findings"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["scan_date", "disclaimer"],
      "properties": {
        "scan_date": { "type": "string", "format": "date" },
        "automation": { "type": "string" },
        "disclaimer": { "type": "string" },
        "feeds_checked": {
          "type": "array",
          "items": { "type": "string" },
          "description": "IDs from data/approved-source-feeds.yaml checked this run"
        },
        "material_delta": {
          "type": "boolean",
          "description": "false when no new findings beyond prior scan"
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "relevance", "topic", "summary", "confidence"],
        "properties": {
          "source": {
            "type": "object",
            "required": ["title", "type"],
            "properties": {
              "title": { "type": "string" },
              "url": { "type": ["string", "null"], "format": "uri" },
              "type": { "type": "string" }
            }
          },
          "relevance": { "type": "string" },
          "topic": { "type": "string" },
          "summary": { "type": "string" },
          "confidence": { "enum": ["low", "medium", "high"] },
          "evidence_tier": { "enum": ["A", "B", "C", "D", "E"] },
          "claim_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "suggested_footnote": {
            "type": "string",
            "description": "footnote_id from wp15-core-references.yaml e.g. ^1"
          },
          "links_to": {
            "type": "object",
            "properties": {
              "overlap_signals": {
                "type": "array",
                "items": { "type": "string" }
              },
              "tap_use_cases": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
