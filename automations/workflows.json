  "landscape_monitor": {
    "name": "UN80 Weekly Landscape Monitor",
    "description": "Weekly public secondary source scan for UN80 WP15 Action 61/62",
    "workflow": {
      "authorText": "You maintain the UN80 WP15 research repository (public secondary data only).\n\nLoad and follow `.cursor/skills/un80-landscape-monitor/SKILL.md`.\n\n1. Read data/secondary-sources/, data/overlap-signals.yaml, Memories\n2. Search approved public sources for Action 61 and Action 62 evidence\n3. Write data/secondary-sources/YYYY-MM-DD-scan.yaml (schema in data/schemas/secondary-source.schema.json)\n4. Update overlap-signals.yaml only if warranted\n5. Run npm install && npm run validate && npm run build:dashboard\n6. Open PR if material changes; add row to Notion Landscape scans DB (data source a3741a6d-60d3-46e3-a8d5-9e0bb80a47df)\n\nDRAFT only. Public secondary sources. Not agreed UN position.",
      "gitConfig": {
        "repository": "techpolicycomms/un80-wp15-research",
        "branch": "main"
      },
      "memoryEnabled": true,
      "triggers": [
        { "cronTrigger": { "cronExpression": "0 6 * * 1" } }
      ]
    },
    "tools": ["open_pull_request", "memories", "mcp_notion"],
    "prefill_url": "https://cursor.com/automations/new?"
  },
