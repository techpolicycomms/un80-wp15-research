# Copy to .env and fill after saving the webhook automation in Cursor
#
# WEBHOOK_URL = copy the full Webhook URL from Cursor (starts with https://)
# WEBHOOK_API_KEY = copy ONLY the key/token — NOT "Authorization: Bearer "
#
# Correct:
#   WEBHOOK_API_KEY=crsr_abc123...
# Wrong:
#   WEBHOOK_API_KEY=Authorization: Bearer crsr_abc123...

WEBHOOK_URL=
WEBHOOK_API_KEY=
